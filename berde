<script>
// ============================================================
// STORAGE — IndexedDB (nombre fijo, persiste entre versiones)
// Fallback a localStorage si IndexedDB no está disponible
// ============================================================
const S = (function(){
  const DB_NAME = 'MetoGroupDB';   // <- nombre FIJO, no cambia nunca
  const DB_VER  = 1;
  const STORE   = 'kv';
  let _db = null;
  let _ready = false;
  let _queue = [];          // callbacks esperando a que la DB abra
  let _cache = {};          // caché en memoria para acceso síncrono

  // Abrir (o crear) la base
  function _open(){
    if(!window.indexedDB){ _ready=true; return; }
    const req = indexedDB.open(DB_NAME, DB_VER);
    req.onupgradeneeded = e => {
      const db = e.target.result;
      if(!db.objectStoreNames.contains(STORE)) db.createObjectStore(STORE);
    };
    req.onsuccess = e => {
      _db = e.target.result;
      // Cargar todo en caché para acceso síncrono
      const tx = _db.transaction(STORE,'readonly');
      const s  = tx.objectStore(STORE);
      const all = s.getAll();
      const allK = s.getAllKeys();
      let gotVals=false, gotKeys=false, vals=[], keys=[];
      all.onsuccess  = ev => { vals=ev.target.result; gotVals=true; if(gotKeys) _finish(keys,vals); };
      allK.onsuccess = ev => { keys=ev.target.result; gotKeys=true; if(gotVals) _finish(keys,vals); };
    };
    req.onerror = () => { _ready=true; _flush(); };
  }

  function _finish(keys,vals){
    keys.forEach((k,i)=>{ _cache[k]=vals[i]; });
    _ready=true;
    _flush();
  }

  function _flush(){
    _queue.forEach(fn=>fn());
    _queue=[];
  }

  function _idbSet(k,v){
    if(_db){
      const tx=_db.transaction(STORE,'readwrite');
      tx.objectStore(STORE).put(v,k);
    }
    // También escribir en localStorage como respaldo
    try{ localStorage.setItem('mg_'+k, JSON.stringify(v)); }catch(e){}
  }

  _open();

  return {
    onReady(fn){ _ready ? fn() : _queue.push(fn); },
    get(k){
      // 1) caché de IndexedDB (cargado al inicio)
      if(_cache[k] !== undefined) return _cache[k];
      // 2) fallback localStorage
      try{ const v=JSON.parse(localStorage.getItem('mg_'+k)); if(v!==null) return v; }catch(e){}
      return [];
    },
    set(k,v){
      _cache[k]=v;
      _idbSet(k,v);
    },
    nextId(k){ const a=this.get(k); return a.length?Math.max(...a.map(i=>i.id||0))+1:1; },
    // Migrar datos desde localStorage a IndexedDB (se llama una sola vez al arrancar)
    migrateFromLS(){
      const staticKeys=['auditorias','auditores','clientes','cotizaciones','proyectos','gastos','cobros',
                  'vendedores','usuarios','crm_logs','crm_seguimientos','crm_objetivos',
                  'crm_premios','crm_notas_vend','crm_referidos'];
      // También migrar claves dinámicas de notas por vendedor (crm_notas_vend_1, crm_notas_vend_2, etc.)
      const dynamicKeys=[];
      for(let i=0;i<localStorage.length;i++){
        const k=localStorage.key(i);
        if(k&&k.startsWith('mg_crm_notas_vend_')){
          dynamicKeys.push(k.replace('mg_',''));
        }
      }
      const allKeys=[...staticKeys,...dynamicKeys];
      let migrated=0;
      allKeys.forEach(k=>{
        // Migrar si: no está en caché, O está en caché como array vacío pero localStorage tiene datos
        const cacheEmpty = _cache[k]===undefined || (Array.isArray(_cache[k])&&_cache[k].length===0);
        if(!cacheEmpty) return;
        try{
          const raw=localStorage.getItem('mg_'+k);
          if(raw){
            const v=JSON.parse(raw);
            if(v!==null&&(Array.isArray(v)?v.length>0:true)){ _cache[k]=v; _idbSet(k,v); migrated++; }
          }
        }catch(e){}
      });
      if(migrated>0) console.log(`MetoGroup: ${migrated} colección(es) migradas de localStorage a IndexedDB`);
    }
  };
})();

const PAGE_TITLES={dashboard:'Dashboard',auditorias:'Auditorías',calendario:'Calendario',auditores:'Auditores',clientes:'Clientes',cotizaciones:'Cotizaciones',proyectos:'Proyectos',gastos:'Gastos',cobros:'Cobros / Cuotas',vendedores:'Vendedores',crm:'CRM Comercial',reportes:'Reportes',historial:'Historial Financiero Mensual',usuarios:'Usuarios',misventas:'Mis Ventas',referidos:'Referidos',agenda:'Agenda Disponible',rankings:'Rankings del Equipo'};
