function renderAuditorias(){
  const items=S.get('auditorias');
  const el=document.getElementById('auditorias-content');
  if(!items.length){el.innerHTML=`<div class="empty-state"><div class="icon">🔍</div><h3>Sin auditorías</h3><p>Creá la primera auditoría</p></div>`;return;}
  el.innerHTML=`<div class="table-wrap">
    <div class="table-header">
      <div class="table-title">Auditorías (${items.length})</div>
      <input placeholder="🔍 Buscar..." style="width:200px;padding:7px 12px;font-size:12px" oninput="filterAuds(this.value)" id="aud-search">
    </div>
    <table><thead><tr><th>Empresa</th><th>Tipo</th><th>Vendedor</th><th>Auditor</th><th>In-Situ</th><th>Informe</th><th>Estado</th><th>Monto</th><th></th></tr></thead>
    <tbody id="aud-tbody">${audsRows(items)}</tbody></table></div>`;
}

function audsRows(items){
  return items.map(a=>{
    const d=diffDays(a.fInsitu);
    const ic=d!==null&&d<0?'color:var(--danger)':d!==null&&d<=7?'color:var(--warn)':'';
    return`<tr onclick="auditDetail(${a.id})" style="cursor:pointer">
      <td><div style="font-weight:500">${a.clienteNombre||'-'}</div><div style="font-size:10px;color:var(--muted)">${a.tipo}</div></td>
      <td style="font-size:11px;color:var(--accent)">${a.tipo}</td>
      <td style="font-size:12px">${a.vendedor||'-'}</td>
      <td style="font-size:12px">${a.auditor||'-'}</td>
      <td style="${ic}">${fmtD(a.fInsitu)}</td>
      <td style="color:var(--accent3)">${fmtD(a.fInforme)}</td>
      <td>${badge(a.estado)}</td>
      <td style="color:var(--accent3);font-weight:600">${fmt(a.monto)}</td>
      <td style="white-space:nowrap">
        <button class="btn btn-secondary btn-sm" onclick="event.stopPropagation();editAuditoria(${a.id})">✏️</button>
        <button class="btn btn-danger btn-sm" onclick="event.stopPropagation();delItem('auditorias',${a.id},renderAuditorias)">🗑</button>
      </td>
    </tr>`;
  }).join('');
}

function filterAuds(q){
  const items=S.get('auditorias').filter(a=>
    [a.clienteNombre,a.tipo,a.auditor,a.vendedor].some(v=>v?.toLowerCase().includes(q.toLowerCase()))
  );
  document.getElementById('aud-tbody').innerHTML=audsRows(items);
}

function auditDetail(id){
  const a=S.get('auditorias').find(x=>x.id===id);if(!a)return;
  const td=todayStr();
  const steps=[
    {lbl:'Venta',f:a.fInicio},{lbl:'Doc. Auditor',f:a.fDoc},{lbl:'Aud. Externa',f:a.fExterna},
    {lbl:'Aud. In-Situ',f:a.fInsitu},{lbl:'Preparación',f:a.fPrep},{lbl:'Informe Final',f:a.fInforme},{lbl:'Seguimiento',f:a.fSeguimiento}
  ];
  const stHtml=steps.map(s=>{
    let cls='',icon='○';
    if(!s.f){icon='—';}
    else if(s.f<td){cls='s-done';icon='✓';}
    else if(s.f===td){cls='s-active';icon='▶';}
    else if(diffDays(s.f)<=3){cls='s-overdue';icon='!';}
    return`<div class="step ${cls}"><div class="step-dot">${icon}</div><div class="step-label">${s.lbl}<br><span style="color:${s.f?'var(--accent)':'var(--muted)'};font-size:9px">${s.f?fmtD(s.f):'-'}</span></div></div>`;
  }).join('');
  const dtHtml=`<div class="audit-dates">
    <div class="audit-date-item"><div class="audit-date-label">📌 Inicio</div><div class="audit-date-val">${fmtD(a.fInicio)}</div></div>
    <div class="audit-date-item"><div class="audit-date-label">📂 Entrega Doc.</div><div class="audit-date-val ${dateValClass(a.fDoc)}">${fmtD(a.fDoc)}</div></div>
    <div class="audit-date-item"><div class="audit-date-label">🔬 Aud. Externa</div><div class="audit-date-val ${dateValClass(a.fExterna)}">${fmtD(a.fExterna)}</div></div>
    <div class="audit-date-item"><div class="audit-date-label">🏢 Aud. In-Situ</div><div class="audit-date-val ${dateValClass(a.fInsitu)}">${fmtD(a.fInsitu)}</div></div>
    <div class="audit-date-item"><div class="audit-date-label">📝 Prep. Informe</div><div class="audit-date-val ${dateValClass(a.fPrep)}">${fmtD(a.fPrep)}</div></div>
    <div class="audit-date-item"><div class="audit-date-label">✅ Informe Final</div><div class="audit-date-val ${dateValClass(a.fInforme)}">${fmtD(a.fInforme)}</div></div>
  </div>`;
  const ov=document.createElement('div');
  ov.className='modal-overlay open';
  ov.innerHTML=`<div class="modal modal-lg">
    <div class="modal-head">
      <div><div class="modal-title">${a.clienteNombre}</div><div style="font-size:11px;color:var(--muted);margin-top:3px">${a.tipo} · ${badge(a.estado)}</div></div>
      <button class="modal-close" onclick="this.closest('.modal-overlay').remove()">✕</button>
    </div>
    <div class="modal-body">
      <div style="display:flex;gap:20px;flex-wrap:wrap;margin-bottom:18px">
        <div><div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:1px">Vendedor</div><div style="font-weight:600;margin-top:3px">${a.vendedor||'-'}</div></div>
        <div><div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:1px">Auditor</div><div style="font-weight:600;margin-top:3px">${a.auditor||'-'}</div></div>
        <div><div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:1px">Monto</div><div style="font-weight:600;color:var(--accent3);margin-top:3px">${fmt(a.monto)}</div></div>
        ${a.notas?`<div><div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:1px">Notas</div><div style="font-size:12px;margin-top:3px">${a.notas}</div></div>`:''}
      </div>
      <div class="form-section" style="margin-top:0">⏳ Progreso</div>
      <div class="steps">${stHtml}</div>
      <div class="form-section">📅 Fechas Clave</div>
      ${dtHtml}
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" onclick="this.closest('.modal-overlay').remove()">Cerrar</button>
      <button class="btn btn-primary" onclick="this.closest('.modal-overlay').remove();editAuditoria(${a.id})">✏️ Editar</button>
    </div>
  </div>`;
  ov.addEventListener('click',e=>{if(e.target===ov)ov.remove();});
  document.body.appendChild(ov);
}

