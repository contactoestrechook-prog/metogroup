  const estadoStyle=s=>({
    Pendiente:{bg:'rgba(99,102,241,0.1)',bd:'rgba(99,102,241,0.3)',cl:'#a5b4fc',ic:'⏳'},
    Contactado:{bg:'rgba(0,212,255,0.08)',bd:'rgba(0,212,255,0.2)',cl:'var(--accent)',ic:'📞'},
